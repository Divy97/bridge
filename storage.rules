rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match files in rooms/{roomCode}/{fileId}/{fileName}
    match /rooms/{roomCode}/{fileId}/{fileName} {
      // Allow authenticated users (anonymous auth) to read files
      allow read: if request.auth != null;
      
      // Allow authenticated users to upload files (max 10MB)
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf|text/.*|application/json');
      
      // Allow authenticated users to delete files
      allow delete: if request.auth != null;
    }
  }
}
